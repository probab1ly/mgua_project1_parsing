# Copy this file to .env on a local/VPS deployment and fill real values.
# Do not commit .env with passwords.

AI_MONITOR_SMTP_HOST=smtp.gmail.com
AI_MONITOR_SMTP_PORT=587
AI_MONITOR_SMTP_USERNAME=your-address@gmail.com
AI_MONITOR_SMTP_PASSWORD=your-google-app-password-without-spaces
AI_MONITOR_SMTP_TIMEOUT=90

# Use 1 on HTTPS hosting.
AI_MONITOR_HTTPS=1
AI_MONITOR_PROXY_FIX=1

# Production server settings.
HOST=0.0.0.0
PORT=5000
WAITRESS_THREADS=8

# Keep disabled on hosting unless you deliberately want this instance
# to run weekly parsing jobs and send email notifications.
AI_MONITOR_ENABLE_SCHEDULER=0

# Local desktop convenience only. Keep 0 on hosting.
AI_MONITOR_OPEN_BROWSER=0

# Generate a long random value for production, at least 32 characters.
AI_MONITOR_SECRET_KEY=replace-with-long-random-secret-key-at-least-32-chars
